<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Rider/ReSharper backend plugin. TargetFramework follows the SDK used
         by the platformVersion in gradle.properties (net8.0 for 2024.3). -->
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <AssemblyName>RiderMcp</AssemblyName>
    <RootNamespace>RiderMcp</RootNamespace>
    <!-- ReSharper SDK packages are restored from JetBrains' feed; the version
         must line up with platformVersion. -->
    <DefineConstants>$(DefineConstants);RIDER</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <!-- Wave version follows the Rider release (e.g. 2024.3 -> 243.x). -->
    <PackageReference Include="JetBrains.Rider.SDK" Version="2024.3.*" />
    <PackageReference Include="JetBrains.Rd" Version="2024.3.*" />
  </ItemGroup>

  <ItemGroup>
    <!-- Generated by rdgen (:protocol). Created at build time; safe to keep
         out of source control (see .gitignore). -->
    <Compile Include="Model/**/*.cs" />
  </ItemGroup>

</Project>
