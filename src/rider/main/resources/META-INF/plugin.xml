<idea-plugin>
    <id>dev.ridermcp</id>
    <name>Rider MCP</name>
    <vendor>gaetan</vendor>

    <description><![CDATA[
        Exposes Rider IDE interface and debug data to MCP clients over a local
        Streamable HTTP endpoint. Dual-part plugin: a Kotlin frontend hosts the MCP
        server; a .NET (ReSharper) backend supplies symbol/solution data over
        the RD protocol.
    ]]></description>

    <!-- Rider == IntelliJ platform + .NET backend -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.rider</depends>

    <extensions defaultExtensionId="com.intellij">
        <!-- NB: McpServerService and DebugDataProvider are registered via their
             @Service annotations — do NOT also declare them here, or the
             duplicate registration aborts the rest of this extensions block
             (which previously swallowed the postStartupActivity + notificationGroup). -->

        <!-- Start the MCP server when a solution opens. -->
        <postStartupActivity
            implementation="dev.ridermcp.McpServerStartup"/>

        <!-- Balloon notifications for the manual start action. -->
        <notificationGroup id="RiderMcp" displayType="BALLOON"/>
    </extensions>

    <!-- Primary auto-start: fires on IDE start, no solution needed. -->
    <applicationListeners>
        <listener class="dev.ridermcp.McpAppStartup"
                  topic="com.intellij.ide.AppLifecycleListener"/>
    </applicationListeners>

    <actions>
        <!-- Manual fallback / verification: Tools | Start MCP Server -->
        <action id="dev.ridermcp.StartMcpServer"
                class="dev.ridermcp.StartMcpServerAction"
                text="Start MCP Server"
                description="Starts the Rider MCP Streamable HTTP server if it isn't already running.">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
